---
import Container from "@components/Container.astro";
import { SITE } from "@lib/site";
const path = new URL(Astro.request.url).pathname;
const isActive = (href: string) => href === "/" ? path === "/" : path.startsWith(href);
---
<header
  data-header
  class="sticky top-0 z-50 bg-white border-b-2 border-slate-900"
>
  <Container class="flex h-14 items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-7 h-7 flex items-center justify-center shrink-0 bg-blue-600 group-hover:bg-blue-700 transition-colors">
        <span class="text-white font-black text-xs leading-none">W</span>
      </div>
      <span class="font-black text-sm leading-tight hidden sm:block tracking-tight text-slate-900">
        De Theorie<span class="text-blue-600">Winkel</span>
      </span>
    </a>

    <nav class="hidden items-center gap-0 lg:flex" aria-label="Hoofdmenu">
      {SITE.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-4 py-3.5 text-xs font-bold uppercase tracking-wider transition border-b-2",
            isActive(item.href)
              ? "text-slate-900 border-blue-600"
              : "text-slate-500 border-transparent hover:text-slate-900 hover:border-slate-300",
          ]}
        >{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href="/blog/" class="hidden sm:inline-flex items-center gap-1 bg-blue-600 hover:bg-blue-700 px-4 py-2 text-xs font-bold text-white transition-colors uppercase tracking-wider">
        Studiegids →
      </a>
      <button
        data-menu-toggle
        class="inline-flex items-center justify-center p-2 text-slate-500 lg:hidden hover:text-slate-900"
        aria-label="Menu openen" aria-expanded="false"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </Container>

  <div data-mobile-menu class="hidden border-t border-slate-200 bg-white lg:hidden">
    <Container class="flex flex-col py-2">
      {SITE.nav.map((item) => (
        <a href={item.href} class="px-2 py-2.5 text-sm font-bold text-slate-600 hover:text-slate-900 uppercase tracking-wider transition-colors">{item.label}</a>
      ))}
    </Container>
  </div>
</header>

<script>
  const toggle = document.querySelector("[data-menu-toggle]");
  const menu = document.querySelector("[data-mobile-menu]");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
