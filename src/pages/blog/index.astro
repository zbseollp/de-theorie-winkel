---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts, displayTitle } from "@lib/posts";

const posts = await getHomepagePosts();
---
<BaseLayout
  title="Studiegids — alle artikelen | De Theorie Winkel"
  description="De complete studiegids voor je CBR theorie-examen. Alle artikelen over verkeersregels, examentips en rijbewijs."
>
  <!-- Smal zwart header-balk, encyclopedie-stijl -->
  <div class="bg-slate-950 text-white">
    <Container class="py-10">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500 mb-2">De Theorie Winkel</p>
      <div class="flex items-end justify-between flex-wrap gap-4">
        <h1 class="text-4xl font-black tracking-tight">Studiegids</h1>
        <span class="text-slate-500 text-sm font-mono">{posts.length} artikelen</span>
      </div>
    </Container>
  </div>

  <!-- Register: artikel lijst als doorlopend register -->
  <Container class="py-(--spacing-section)">
    <div class="grid gap-px bg-slate-200 border border-slate-200">
      {posts.map((p) => <BlogPostCard post={p} />)}
    </div>
  </Container>
</BaseLayout>
