---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts, displayTitle, displayDescription } from "@lib/posts";

const posts = await getHomepagePosts();
const [lead, ...rest] = posts;
const leadTitle = lead ? displayTitle(lead) : "";
const leadDesc = lead ? displayDescription(lead) : "";
---
<BaseLayout
  title="Studiegids — alle artikelen over je theorie-examen | De Theorie Winkel"
  description="De complete studiegids voor je CBR theorie-examen. Verkeersregels, examentips, rijschool en alles rondom je rijbewijs."
>
  <!-- Studiegids header: navy blue -->
  <section class="bg-blue-800 text-white">
    <Container class="py-14">
      <div class="flex items-end justify-between flex-wrap gap-4">
        <div>
          <div class="text-xs font-bold uppercase tracking-wider text-blue-300 mb-2">De TheorieWinkel</div>
          <h1 class="text-4xl font-black tracking-tight">Studiegids</h1>
          <p class="mt-2 text-blue-200 max-w-xl">Alle artikelen voor je CBR theorie-examen. Van verkeersregels tot examentips — alles gratis.</p>
        </div>
        <div class="text-right">
          <div class="text-3xl font-black">{posts.length}</div>
          <div class="text-xs text-blue-300">artikelen beschikbaar</div>
        </div>
      </div>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">

    <!-- Featured (aanbevolen) post -->
    {lead && (
      <a href={`/${lead.id}/`} class="group mb-12 grid overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm hover:shadow-md transition-shadow md:grid-cols-5">
        <div class="md:col-span-2">
          {lead.data.featuredImage ? (
            <img src={lead.data.featuredImage} alt={lead.data.featuredImageAlt || leadTitle}
                 width="800" height="450" loading="eager" fetchpriority="high" decoding="sync"
                 class="aspect-video w-full h-full object-cover" />
          ) : (
            <div class="relative flex aspect-video h-full w-full items-center justify-center bg-gradient-to-br from-blue-800 to-blue-600">
              <span class="font-black text-2xl tracking-tight text-white/80">De Theorie<span class="text-white">Winkel</span></span>
            </div>
          )}
        </div>
        <div class="md:col-span-3 flex flex-col justify-center p-8">
          <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wide text-blue-700 mb-3">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
            Aanbevolen
          </span>
          <h2 class="text-2xl font-black text-slate-900 group-hover:text-blue-700 transition-colors leading-tight">{leadTitle}</h2>
          {leadDesc && <p class="mt-3 line-clamp-3 text-slate-500 text-sm leading-relaxed">{leadDesc}</p>}
          <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-bold text-blue-700">
            Lees in de studiegids <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </div>
      </a>
    )}

    <!-- Rest of posts grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((p) => <BlogPostCard post={p} />)}
    </div>
  </Container>
</BaseLayout>
