---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getRecentPosts } from "@lib/posts";

const posts = await getRecentPosts(6);
---
<BaseLayout
  title="Theorie uitleg — verkeersregels begrijpen | De Theorie Winkel"
  description="Begrijp de verkeersregels voor je CBR theorie-examen. Duidelijke uitleg over voorrang, rijbanen, snelheidslimieten en meer."
>
  <section class="bg-blue-800 text-white">
    <Container class="py-14">
      <div class="text-xs font-bold uppercase tracking-wider text-blue-300 mb-2">De TheorieWinkel</div>
      <h1 class="text-4xl font-black tracking-tight">Theorie uitleg</h1>
      <p class="mt-3 text-blue-200 max-w-xl">Begrijp de verkeersregels. Duidelijke uitleg voor je CBR theorie-examen.</p>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-12">
      {[
        { title: "Voorrangsregels", desc: "Wie heeft voorrang? Kruispunten, rotondes en bijzondere gevallen uitgelegd.", href: "/blog/" },
        { title: "Verkeerstekens", desc: "Wat betekenen de borden, wegmarkeringen en verkeerlichten?", href: "/blog/" },
        { title: "Snelheidslimieten", desc: "Maximumsnelheden in de bebouwde kom, op de autoweg en snelweg.", href: "/blog/" },
        { title: "Gevaarherkenning", desc: "Het moeilijkste onderdeel van het examen: gevaarlijke situaties herkennen.", href: "/blog/" },
        { title: "Rijstroken & rijbanen", desc: "Rijstrookgebruik, inhalen en spookrijden voorkomen.", href: "/blog/" },
        { title: "Bijzondere situaties", desc: "Rotondes, viaducten, parkeren en stil staan correct uitgelegd.", href: "/blog/" },
      ].map(({ title, desc, href }) => (
        <a href={href} class="group rounded-2xl border border-slate-200 bg-white p-6 hover:shadow-md hover:border-blue-300 transition-all">
          <h2 class="font-bold text-slate-900 group-hover:text-blue-700 transition-colors">{title}</h2>
          <p class="mt-2 text-sm text-slate-500 leading-relaxed">{desc}</p>
          <div class="mt-4 text-sm font-semibold text-blue-700 flex items-center gap-1">
            Lees uitleg <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div>
      <h2 class="text-2xl font-black tracking-tight text-slate-900 mb-6">Recente artikelen</h2>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => <BlogPostCard post={p} />)}
      </div>
    </div>
  </Container>
</BaseLayout>
