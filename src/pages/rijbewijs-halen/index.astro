---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
---
<BaseLayout
  title="Rijbewijs halen — stappenplan | De Theorie Winkel"
  description="Hoe haal je je rijbewijs? Stappenplan van aanmelden bij het CBR tot je eerste rijles en praktijkexamen."
>
  <section class="bg-slate-900 text-white">
    <Container class="py-14">
      <div class="text-xs font-bold uppercase tracking-wider text-blue-400 mb-2">De TheorieWinkel</div>
      <h1 class="text-4xl font-black tracking-tight">Rijbewijs halen</h1>
      <p class="mt-3 text-slate-300 max-w-xl">Het complete stappenplan: van aanmelden tot je rijbewijs in handen.</p>
    </Container>
  </section>

  <Container class="max-w-3xl py-(--spacing-section)">

    <!-- Stappenplan -->
    <div class="mb-12">
      <h2 class="text-2xl font-black tracking-tight text-slate-900 mb-6">Stappenplan rijbewijs B</h2>
      <ol class="space-y-4">
        {[
          { n: "1", title: "Aanvraag CBR-code", body: "Registreer je bij het CBR en vraag een rijbewijscode aan. Dit heb je nodig om je theorie-examen in te plannen. Je betaalt hier eenmalig voor." },
          { n: "2", title: "Theorie leren", body: "Gebruik onze studiegids om de verkeersregels te leren. Besteed extra aandacht aan gevaarherkenning — dat onderdeel is het moeilijkst." },
          { n: "3", title: "Theorie-examen doen", body: "Plan je theorie-examen via het CBR. Het examen bestaat uit 65 vragen en duurt 45 minuten. Slagingsnorm: 77% (maximaal 15 fouten)." },
          { n: "4", title: "Rijschool kiezen", body: "Kies een rijschool na je theorie. Je kunt ook andersom: rijles volgen terwijl je theorie nog loopt. Vraag meerdere offertes op." },
          { n: "5", title: "Praktijklessen", body: "Gemiddeld 30-40 rijlessen nodig voor het praktijkexamen. Dat varieert sterk per persoon. Overleg met je rijinstructeur wanneer je rijklaar bent." },
          { n: "6", title: "Praktijkexamen", body: "Plan je praktijkexamen via het CBR zodra je rijklaar bent. Het examen duurt 50-65 minuten. Geslaagd? Je rijbewijs komt per post." },
        ].map(({ n, title, body }) => (
          <li class="flex gap-4 rounded-xl border border-slate-200 bg-white p-5">
            <div class="shrink-0 w-9 h-9 rounded-xl bg-blue-700 text-white flex items-center justify-center font-black text-sm">{n}</div>
            <div>
              <h3 class="font-bold text-slate-900">{title}</h3>
              <p class="mt-1 text-sm text-slate-500 leading-relaxed">{body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- Kosten -->
    <div class="rounded-2xl border border-slate-200 bg-white p-7 mb-10">
      <h2 class="text-xl font-black tracking-tight text-slate-900 mb-4">Wat kost een rijbewijs?</h2>
      <div class="divide-y divide-slate-100">
        {[
          { post: "Theorie-examen", prijs: "€ 42,-" },
          { post: "Rijlessen (per les)", prijs: "€ 45 – 70,-" },
          { post: "Praktijkexamen", prijs: "€ 130,-" },
          { post: "Rijbewijs aanvragen", prijs: "€ 42,-" },
        ].map(({ post, prijs }) => (
          <div class="flex justify-between py-3 text-sm">
            <span class="text-slate-600">{post}</span>
            <span class="font-semibold text-slate-900">{prijs}</span>
          </div>
        ))}
        <div class="flex justify-between py-3 text-sm font-bold border-t border-slate-300">
          <span class="text-slate-900">Totaal gemiddeld</span>
          <span class="text-blue-700">€ 1.800 – 2.500,-</span>
        </div>
      </div>
    </div>

    <div class="rounded-2xl bg-blue-50 border border-blue-200 p-7 text-center">
      <h2 class="text-xl font-black tracking-tight text-slate-900 mb-2">Begin met de studiegids</h2>
      <p class="text-slate-600 text-sm mb-5">Gratis theorie leren voor je CBR theorie-examen. Geen account nodig.</p>
      <a href="/blog/" class="inline-flex items-center gap-2 rounded-xl bg-blue-700 px-6 py-3 text-sm font-bold text-white hover:bg-blue-800 transition-colors">
        Open de studiegids →
      </a>
    </div>
  </Container>
</BaseLayout>
