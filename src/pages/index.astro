---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getRecentPosts } from "@lib/posts";
import { SITE } from "@lib/site";

const recent = await getRecentPosts(8);
---
<BaseLayout title={`${SITE.name} — Studiegids voor je theorie-examen`} description={SITE.description}>

  <!-- Split hero: zwart links / wit rechts -->
  <section class="grid lg:grid-cols-2 min-h-[420px]">
    <div class="bg-slate-950 text-white flex items-center px-8 py-16 md:px-16">
      <div class="max-w-md">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500 mb-4">De Theorie Winkel — studiegids</p>
        <h1 class="text-4xl font-black tracking-tight leading-tight sm:text-5xl">
          Slaag voor je<br/>
          <span class="text-blue-400">theorie-examen.</span><br/>
          Gratis.
        </h1>
        <p class="mt-5 text-slate-400 leading-relaxed text-sm max-w-sm">
          De complete referentiegids voor je CBR theorie-examen. Gestructureerde uitleg van alle verkeersregels, examentips en meer.
        </p>
        <div class="mt-8 flex items-center gap-4">
          <a href="/blog/" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 text-sm font-bold rounded-lg transition-colors">
            Open studiegids →
          </a>
          <a href="/theorie-uitleg/" class="text-sm text-slate-400 hover:text-white transition-colors underline underline-offset-4">
            Theorie uitleg
          </a>
        </div>
      </div>
    </div>
    <div class="bg-slate-100 flex items-center justify-center px-8 py-16 md:px-16">
      <div class="w-full max-w-xs space-y-3">
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-slate-400 mb-5">Examen feiten</p>
        {[
          { label: "Aantal vragen", value: "65" },
          { label: "Slagingsnorm", value: "77%" },
          { label: "Examenduur", value: "45 min" },
          { label: "Certificaat geldig", value: "18 mnd" },
          { label: "Minimale leeftijd", value: "16½ jaar" },
        ].map(({ label, value }) => (
          <div class="flex items-center justify-between border-b border-slate-200 pb-3">
            <span class="text-sm text-slate-600">{label}</span>
            <span class="text-sm font-black text-slate-900">{value}</span>
          </div>
        ))}
        <a href="/rijbewijs-halen/" class="block text-center text-xs font-bold text-blue-700 hover:text-blue-800 pt-2 uppercase tracking-wider">
          Rijbewijs stappenplan →
        </a>
      </div>
    </div>
  </section>

  <!-- Register-stijl artikel lijst -->
  <Container class="py-(--spacing-section)">
    <div class="flex items-end justify-between mb-6 border-b border-slate-900 pb-3">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-slate-400">Studiegids</p>
        <h2 class="text-2xl font-black text-slate-900 mt-1">Recente artikelen</h2>
      </div>
      <a href="/blog/" class="text-xs font-bold uppercase tracking-wider text-blue-700 hover:text-blue-900">
        Alles bekijken →
      </a>
    </div>
    <div class="grid gap-px bg-slate-200 border border-slate-200">
      {recent.map((p) => <BlogPostCard post={p} />)}
    </div>
  </Container>

  <!-- Drie kolommen: uitleg, strategie, examen -->
  <section class="bg-slate-950 text-white">
    <Container class="py-(--spacing-section)">
      <p class="text-xs font-bold uppercase tracking-[0.15em] text-slate-500 mb-8">Wat vind je in de studiegids</p>
      <div class="grid gap-8 sm:grid-cols-3">
        {[
          { n: "I", title: "Theorie uitleg", body: "Begrijp de verkeersregels grondig. Voorrang, rijstroken, snelheidslimieten — alles duidelijk uitgelegd.", href: "/theorie-uitleg/" },
          { n: "II", title: "Examen tips", body: "Hoe haal je het theorie-examen in één keer? Leer de stof slim en besteed extra tijd aan gevaarherkenning.", href: "/blog/" },
          { n: "III", title: "Rijbewijs halen", body: "Van aanmelden bij het CBR tot je rijbewijs in handen. Het complete stappenplan.", href: "/rijbewijs-halen/" },
        ].map(({ n, title, body, href }) => (
          <a href={href} class="group border border-slate-800 hover:border-blue-500 p-6 transition-colors">
            <div class="text-xs font-bold text-slate-600 mb-3 font-mono">{n}</div>
            <h3 class="font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">{title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{body}</p>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- FAQ: strak, zwart-wit -->
  <Container class="max-w-2xl py-(--spacing-section)">
    <p class="text-xs font-bold uppercase tracking-[0.15em] text-slate-400 mb-2">Vragen</p>
    <h2 class="text-2xl font-black text-slate-900 mb-8">Veelgesteld</h2>
    <div class="space-y-0 border-t border-slate-200">
      {[
        { q: "Hoeveel vragen heeft het CBR theorie-examen?", a: "65 meerkeuzevragen, verdeeld over kennis, inzicht en gevaarherkenning." },
        { q: "Wat is de slagingsnorm?", a: "Minimaal 77% goed — maximaal 15 fouten op 65 vragen." },
        { q: "Hoe lang duurt het examen?", a: "45 minuten. Met extra tijd indien van toepassing (bijv. dyslexie)." },
        { q: "Hoe lang is mijn certificaat geldig?", a: "18 maanden. Binnen die periode moet je ook het praktijkexamen halen." },
      ].map(({ q, a }) => (
        <details class="group border-b border-slate-200 py-4">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-semibold text-slate-900 list-none gap-4">
            {q}
            <span class="text-lg font-light text-slate-400 group-open:rotate-45 transition-transform shrink-0">+</span>
          </summary>
          <p class="mt-3 text-sm text-slate-500 leading-relaxed">{a}</p>
        </details>
      ))}
    </div>
  </Container>

</BaseLayout>
